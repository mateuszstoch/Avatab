<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             xmlns:converters="clr-namespace:Avatab.Converters"
             x:Class="Avatab.MainPage"
             xmlns:vm="clr-namespace:Avatab.ViewModel"
             xmlns:v="clr-namespace:Avatab.View"
             xmlns:model="clr-namespace:Avatab.Model"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#F5F5F5"
             >
    <VerticalStackLayout Spacing="10">
        <Grid ColumnDefinitions="*,auto,auto" ColumnSpacing="10">
             <Button
                 Margin="10"
                 Text="+"
                 FontSize="20"
                 WidthRequest="40"
                 HeightRequest="40"
                 CornerRadius="50"
                 Padding="0"
                 BackgroundColor="#4CAF50"
                 TextColor="White"
                 Command="{Binding AddEventCommand}" 
                 Grid.Column="1">

            </Button>
            <ImageButton 
                 Margin="10"
                 Source="settings.png"
                 WidthRequest="40"
                 HeightRequest="40"
                 CornerRadius="50"
                 Padding="0"
                 BackgroundColor="Transparent"
                 Command="{Binding SettingsCommand}" 
                Grid.Column="2">

            </ImageButton>
        </Grid>

   
        <v:Calendar x:Name="MyCalendar"
                                   HeightRequest="600"
                                   HorizontalOptions="Fill" />

        
    </VerticalStackLayout>
</ContentPage>
