<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
             xmlns:converters="clr-namespace:Avatab.Converters"
             x:Class="Avatab.MainPage"
             xmlns:vm="clr-namespace:Avatab.ViewModel"
             xmlns:v="clr-namespace:Avatab.View"
             xmlns:model="clr-namespace:Avatab.Model"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#F5F5F5"
             >
    <VerticalStackLayout Spacing="10">
        <Label Text="Moja aplikacja z kalendarzem" FontSize="24" HorizontalOptions="Center" />

   
        <v:Calendar x:Name="MyCalendar"
                                   HeightRequest="600"
                                   HorizontalOptions="Fill" />

        
    </VerticalStackLayout>
</ContentPage>
