<?xml version="1.0" encoding="utf-8" ?>
<mct:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
           xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
           xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
           xmlns:converters="clr-namespace:Avatab.Converters"
           x:Class="Avatab.View.ImportPopup">

    <mct:Popup.Resources>
        <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
        <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#1976D2" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HeightRequest" Value="44" />
        </Style>
    </mct:Popup.Resources>

    <VerticalStackLayout Padding="24" Spacing="12"
                         BackgroundColor="White"
                         WidthRequest="320"
                         MinimumHeightRequest="300"
                         HorizontalOptions="Center">

        <!-- Dwa przyciski wyboru -->
        <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
            <Button Text="Add Person"
                    Command="{Binding ShowAddPersonCommand}"
                    Style="{StaticResource ActionButtonStyle}" />
            <Button Text="Import Schedule"
                    Command="{Binding ShowImportScheduleCommand}"
                    Style="{StaticResource ActionButtonStyle}" />
        </HorizontalStackLayout>

        <!-- Sekcja: Add Person -->
        <StackLayout IsVisible="{Binding IsAddPersonMode}" Spacing="10">
            <Label Text="Name"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#555" />
            <Entry Text="{Binding Name}"
                   Placeholder="Enter name"
                   BackgroundColor="#f5f5f5"
                   TextColor="Black"
                   HeightRequest="40" />
            <Button Text="➕ Add New"
                    Command="{Binding AddNewCommand}"
                    Style="{StaticResource ActionButtonStyle}" />
        </StackLayout>

        <!-- Sekcja: Import Schedule -->
        <StackLayout IsVisible="{Binding IsImportScheduleMode}" Spacing="12">
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="{Binding IsImportFromUsosTogled, Converter={StaticResource BoolToStringConverter}}"
                       Grid.Column="0"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#555"
                       VerticalTextAlignment="Center"/>
                <Switch IsToggled="{Binding IsImportFromUsosTogled}" Grid.Column="1"/>
            </Grid>
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Picker Title="Kliknij aby wybrać"
                    ItemsSource="{Binding Options}"
                    SelectedItem="{Binding SelectedOption, Mode=TwoWay}" />
                <Button Text="Import CSV File"
                        Command="{Binding PickFileCommand}"
                        Style="{StaticResource ActionButtonStyle}"
                   
                       />

            </HorizontalStackLayout>
            <Label Text="{Binding ImportStatus}"
                   FontSize="14"
                   TextColor="Green"
                   IsVisible="{Binding ImportStatus, Converter={StaticResource StringNotEmptyConverter}}" />
            
        </StackLayout>

       
    </VerticalStackLayout>
</mct:Popup>
